{
  "name": "foodjourney",
  "version": "0.1.0",
  "description": "A unique culinary adventure food tracking app with gamification, AI recognition, and social features",
  "private": true,
  "scripts": {
    "dev:web": "npm --prefix web run dev",
    "dev:mobile": "npm --prefix mobile run start",
    "dev:backend": "npm --prefix backend run dev",
    "dev:all": "concurrently \"npm:dev:web\" \"npm:dev:backend\"",
    "build:shared": "npm --prefix shared run build",
    "build:web": "npm --prefix web run build",
    "build:mobile": "npm --prefix mobile run type-check",
    "build:backend": "npm --prefix backend run build",
    "lint:web": "npm --prefix web run lint",
    "lint:backend": "npm --prefix backend run lint",
    "lint:mobile": "npm --prefix mobile run lint",
    "lint": "npm run lint:web && npm run lint:backend && npm run lint:mobile",
    "type-check:shared": "npm --prefix shared run type-check",
    "type-check:web": "npm --prefix web run type-check",
    "type-check:mobile": "npm --prefix mobile run type-check",
    "type-check:backend": "npm --prefix backend run type-check",
    "type-check": "npm run type-check:shared && npm run type-check:web && npm run type-check:mobile && npm run type-check:backend",
    "check": "npm run lint && npm run type-check",
    "test": "npm run check",
    "install:all": "npm install && npm --prefix mobile install"
  },
  "workspaces": [
    "web",
    "backend",
    "shared"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
